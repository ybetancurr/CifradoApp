<Window x:Class="CifradoApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CifradoApp"
        Height="600" Width="800"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F4F4F6">

    <Window.Resources>
        <!-- Estilo base botón de navegación -->
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="8,2"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#AAAACC"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2A2A45"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Estilo botón activo (seleccionado) -->
        <Style x:Key="NavButtonActive" TargetType="Button" BasedOn="{StaticResource NavButton}">
            <Setter Property="Background" Value="#2E2060"/>
            <Setter Property="Foreground" Value="#A78BFA"/>
        </Style>

        <!-- Estilo botón salir -->
        <Style x:Key="NavButtonDanger" TargetType="Button" BasedOn="{StaticResource NavButton}">
            <Setter Property="Foreground" Value="#FF6666"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3A1A1A"/>
                                <Setter Property="Foreground" Value="#FF9999"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ SIDEBAR ═══ -->
        <Border Grid.Column="0" Background="#1A1A2E">
            <DockPanel>

                <!-- Header: logo + título -->
                <Border DockPanel.Dock="Top"
                        BorderBrush="#33334A"
                        BorderThickness="0,0,0,1"
                        Padding="18,22,18,18">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔐"
                                   FontSize="18"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"/>
                        <StackPanel>
                            <TextBlock Text="CIFRADOAPP"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#FFFFFF"/>
                            <TextBlock Text="v1.0 · .NET 7"
                                       FontSize="10"
                                       Foreground="#55556A"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Footer: botón salir -->
                <Border DockPanel.Dock="Bottom"
                        BorderBrush="#33334A"
                        BorderThickness="0,1,0,0"
                        Padding="8,10">
                    <Button x:Name="btnSalir"
                            Style="{StaticResource NavButtonDanger}"
                            Click="btnSalir_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⎋" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Salir" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Border>

                <!-- Nav: botones de navegación -->
                <StackPanel DockPanel.Dock="Top" Margin="0,12,0,0">
                    <Button x:Name="btnInicio"
                            Style="{StaticResource NavButtonActive}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⌂" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Inicio" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="btnCifrar"
                            Style="{StaticResource NavButton}"
                            Click="btnCifrar_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔒" FontSize="13" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Cifrar" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="btnDescifrar"
                            Style="{StaticResource NavButton}"
                            Click="btnDescifrar_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔓" FontSize="13" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Descifrar" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

            </DockPanel>
        </Border>

        <!-- ═══ ÁREA PRINCIPAL ═══ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="52"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Topbar -->
            <Border Grid.Row="0"
                    Background="#FFFFFF"
                    BorderBrush="#E5E5EA"
                    BorderThickness="0,0,0,1">
                <Grid Margin="20,0">
                    <TextBlock x:Name="lblTopbarTitle"
                               Text="Panel principal"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#1A1A2E"
                               VerticalAlignment="Center"/>
                    <Border HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Background="#F4F4F6"
                            BorderBrush="#E0E0E8"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="10,3">
                        <TextBlock x:Name="lblTopbarBadge"
                                   Text="Inicio"
                                   FontSize="11"
                                   Foreground="#888899"/>
                    </Border>
                </Grid>
            </Border>

            <!-- Contenedor dinámico -->
            <ContentControl x:Name="MainContent"
                            Grid.Row="1"
                            Margin="0"/>
        </Grid>
    </Grid>
</Window>